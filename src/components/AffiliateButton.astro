---
export interface Props { href?: string; url?: string; label: string; small?: boolean; }
const { href, url, label, small = false } = Astro.props;
const link = href || url || '#';
---
<a href={link} class={`aff-btn ${small ? 'aff-btn-sm' : ''}`} rel="sponsored noopener noreferrer" target="_blank">{label} →</a>