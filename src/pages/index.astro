---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const articles = Object.entries(import.meta.glob('../content/articles/*.mdx', { eager: true }))
  .map(([path, mod]: [string, any]) => ({
    ...mod.frontmatter,
    slug: path.split('/').pop()?.replace('.mdx', '') || '',
  }));
const featuredArticles = articles.filter((a) => a.featured);
const allArticles = articles.sort((a, b) =>
  new Date(b.pubDate || b.date || 0).getTime() - new Date(a.pubDate || a.date || 0).getTime()
);
---

<BaseLayout
  title="Wellness Savings"
  description="Save on premium supplements, organic coffee, natural skincare, and wellness products. Daily deals and exclusive discount codes."
  type="website"
>
  <section class="hero">
    <div class="container-narrow">
      <h1>Save Big on Health &amp; Wellness</h1>
      <p>Hand-picked discount codes and exclusive deals on the best supplements, coffee, skincare, and wellness products. Never pay full price again.</p>
    </div>
  </section>

  <div class="container">
    {featuredArticles.length > 0 && (
      <section>
        <h2>Featured Deals</h2>
        <div class="card-grid">
          {featuredArticles.map((article: any) => (
            <ArticleCard title={article.title} description={article.metaDescription || article.description} url={`/articles/${article.slug}/`} category={article.category} date={article.pubDate || article.date} />
          ))}
        </div>
      </section>
    )}

    <section>
      <h2>Latest Deals &amp; Reviews</h2>
      <div class="card-grid">
        {allArticles.map((article: any) => (
          <ArticleCard title={article.title} description={article.metaDescription || article.description} url={`/articles/${article.slug}/`} category={article.category} date={article.pubDate || article.date} />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>