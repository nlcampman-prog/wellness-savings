---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';

export async function getStaticPaths() {
  const articles = Object.entries(import.meta.glob('../../../content/articles/*.mdx', { eager: true }));
  const categorySlugs = new Set<string>();
  articles.forEach(([, mod]: [string, any]) => {
    const cat = mod.frontmatter?.category;
    if (cat) categorySlugs.add(cat.toLowerCase().replace(/\s+/g, '-'));
  });
  return Array.from(categorySlugs).map(slug => ({ params: { slug }, props: {} }));
}

const { slug } = Astro.params;
const articles = Object.entries(import.meta.glob('../../../content/articles/*.mdx', { eager: true }))
  .map(([path, mod]: [string, any]) => ({ ...mod.frontmatter, slug: path.split('/').pop()?.replace('.mdx', '') || '' }));
const matchingArticles = articles
  .filter((a) => { const cat = a.category; return cat && cat.toLowerCase().replace(/\s+/g, '-') === slug; })
  .sort((a, b) => new Date(b.pubDate || b.date || 0).getTime() - new Date(a.pubDate || a.date || 0).getTime());
const categoryName = matchingArticles[0]?.category || slug;
---

<BaseLayout title={`${categoryName} Deals & Discount Codes`} description={`Browse the best ${categoryName.toLowerCase()} deals and discount codes. Save on top wellness products.`}>
  <div class="container">
    <div class="category-header">
      <a href="/categories/" class="card-category" style="margin-bottom: 0.5rem; display: inline-block;">All Categories</a>
      <h1>{categoryName}</h1>
      <p>{matchingArticles.length} deal{matchingArticles.length !== 1 ? 's' : ''}</p>
    </div>
    {matchingArticles.length > 0 ? (
      <div class="card-grid">
        {matchingArticles.map((article: any) => (
          <ArticleCard title={article.title} description={article.metaDescription || article.description} url={`/articles/${article.slug}/`} category={article.category} date={article.pubDate || article.date} />
        ))}
      </div>
    ) : <p>No deals found in this category yet. Check back soon!</p>}
  </div>
</BaseLayout>